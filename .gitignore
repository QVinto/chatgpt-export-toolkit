# Upstream tool (setup.sh clones it at a pinned commit)
/tool/

# Playwright runtime (setup.sh installs it)
/pw/node_modules/
/pw/browsers/
/pw/userdata/
/pw/package-lock.json

# Export output + sensitive / runtime data
/out/
/token.txt
/export.log
/viewer.log
*.zip

# Runtime state files (created by setup.sh / the scripts)
.throttle
.min-throttle
.cooldown-until
.stable-count
.last-count
.last-probe
.wait-count
.runner-state

# Official OpenAI export (per-user, do not commit)
/official-openai/

# OS
.DS_Store

# Claude Code worktrees / agent runtime
/.claude/
